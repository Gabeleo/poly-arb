{
  "uid": "polyarb-providers",
  "title": "Polyarb — Data Providers",
  "tags": ["polyarb"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "provider",
        "type": "custom",
        "query": "poly,kalshi",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Fetch Latency by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(polyarb_fetch_duration_seconds_bucket{provider=~\"$provider\"}[5m]))",
          "legendFormat": "p50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(polyarb_fetch_duration_seconds_bucket{provider=~\"$provider\"}[5m]))",
          "legendFormat": "p95 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(polyarb_fetch_duration_seconds_bucket{provider=~\"$provider\"}[5m]))",
          "legendFormat": "p99 {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Fetch Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(polyarb_fetch_errors_total{provider=~\"$provider\"}[5m])",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Markets Fetched",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "polyarb_markets_fetched{provider=~\"$provider\"}",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 4,
      "title": "Circuit Breaker State",
      "type": "state-timeline",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "polyarb_circuit_breaker_state{provider=~\"$provider\"}",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Fetch Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 12 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "1 - (rate(polyarb_fetch_errors_total{provider=~\"$provider\"}[1h]) / sum(rate(polyarb_scan_total[1h])))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.9, "color": "yellow" },
              { "value": 0.99, "color": "green" }
            ]
          }
        }
      }
    }
  ]
}
